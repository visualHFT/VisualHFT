<Window x:Class="OxyplotBenchmark.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:OxyplotBenchmark"
        mc:Ignorable="d"
        Title="MainWindow" Height="600" Width="600">
    <Grid>
        <Button Name="btnStart" Content="Start Benchmark" Margin="0,5" HorizontalAlignment="Center" VerticalAlignment="Top" Width="120" Height="30" Click="btnStart_Click"/>
        <Label Name="lblResultsOffical" HorizontalAlignment="Left" VerticalAlignment="Top" Margin="10,40,0,0" Content="Official Oxyplot:" FontSize="14"/>
        <Label Name="lblResultsForked" HorizontalAlignment="Right" VerticalAlignment="Top" Margin="10,40,0,0" Content="Forked Oxyplot:" FontSize="14"/>
    </Grid>
</Window>

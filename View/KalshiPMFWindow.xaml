<Window x:Class="VisualHFT.View.KalshiPMFWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="{Binding WindowTitle}"
        Height="540" Width="640"
        Background="#FF1A1A1A"
        TextElement.Foreground="White"
        FontFamily="Consolas"
        FontSize="13">
    <Window.Resources>
        <Style TargetType="DataGridColumnHeader">
            <Setter Property="Background" Value="#FF252526"/>
            <Setter Property="Foreground" Value="#FF999999"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="Padding" Value="6,4"/>
            <Setter Property="HorizontalContentAlignment" Value="Left"/>
        </Style>
        <Style TargetType="DataGridCell">
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="6,3"/>
            <Setter Property="Background" Value="Transparent"/>
        </Style>
        <Style TargetType="DataGridRow">
            <Setter Property="Background" Value="#FF1F1F1F"/>
            <Setter Property="Foreground" Value="#FFCCCCCC"/>
        </Style>
    </Window.Resources>

    <DockPanel LastChildFill="True">
        <Border DockPanel.Dock="Top" Background="#FF252526" Padding="14,10">
            <StackPanel>
                <TextBlock FontSize="16" FontWeight="Bold" Foreground="White">
                    <Run Text="📊 Implied PMF — "/>
                    <Run Text="{Binding EventTicker}" Foreground="#FF8AB4F8"/>
                </TextBlock>
                <StackPanel Orientation="Horizontal" Margin="0,6,0,0">
                    <TextBlock Text="Bins: " Foreground="#FF999999"/>
                    <TextBlock Text="{Binding BinsCount}" Foreground="#FFCCCCCC" FontWeight="Bold"/>
                    <TextBlock Text="    Median: " Foreground="#FF999999" Margin="20,0,0,0"/>
                    <TextBlock Text="{Binding MedianText}" Foreground="#FFFFD54F" FontWeight="Bold"/>
                    <TextBlock Text="    Updated: " Foreground="#FF999999" Margin="20,0,0,0"/>
                    <TextBlock Text="{Binding LastUpdate, StringFormat='HH:mm:ss'}" Foreground="#FFCCCCCC"/>
                </StackPanel>
                <TextBlock Text="The market's implied distribution over outcome regions, derived from the strike ladder."
                           Foreground="#FF777777" FontSize="10" Margin="0,4,0,0"/>
            </StackPanel>
        </Border>

        <DataGrid ItemsSource="{Binding Bins}"
                  AutoGenerateColumns="False"
                  CanUserAddRows="False"
                  CanUserDeleteRows="False"
                  IsReadOnly="True"
                  HeadersVisibility="Column"
                  GridLinesVisibility="None"
                  Background="#FF1A1A1A"
                  BorderThickness="0">
            <DataGrid.Columns>
                <DataGridTextColumn Header="Range" Binding="{Binding Range}" Width="160">
                    <DataGridTextColumn.ElementStyle>
                        <Style TargetType="TextBlock">
                            <Setter Property="Foreground" Value="#FFCCCCCC"/>
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding IsLeftTail}"  Value="True"><Setter Property="Foreground" Value="#FF888888"/></DataTrigger>
                                <DataTrigger Binding="{Binding IsRightTail}" Value="True"><Setter Property="Foreground" Value="#FF888888"/></DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </DataGridTextColumn.ElementStyle>
                </DataGridTextColumn>
                <DataGridTextColumn Header="Probability" Binding="{Binding ProbText}" Width="100">
                    <DataGridTextColumn.ElementStyle>
                        <Style TargetType="TextBlock">
                            <Setter Property="HorizontalAlignment" Value="Right"/>
                            <Setter Property="FontWeight" Value="Bold"/>
                            <Setter Property="Foreground" Value="#FF8AB4F8"/>
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding IsPeak}" Value="True"><Setter Property="Foreground" Value="#FFFFD54F"/></DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </DataGridTextColumn.ElementStyle>
                </DataGridTextColumn>
                <DataGridTemplateColumn Header="Distribution" Width="*">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <Grid>
                                <Rectangle Height="20" HorizontalAlignment="Left"
                                           Width="{Binding BarWidth}">
                                    <Rectangle.Style>
                                        <Style TargetType="Rectangle">
                                            <Setter Property="Fill" Value="#558AB4F8"/>
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding IsPeak}" Value="True">
                                                    <Setter Property="Fill" Value="#88FFD54F"/>
                                                </DataTrigger>
                                                <DataTrigger Binding="{Binding IsLeftTail}" Value="True">
                                                    <Setter Property="Fill" Value="#33888888"/>
                                                </DataTrigger>
                                                <DataTrigger Binding="{Binding IsRightTail}" Value="True">
                                                    <Setter Property="Fill" Value="#33888888"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Rectangle.Style>
                                </Rectangle>
                            </Grid>
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>
            </DataGrid.Columns>
        </DataGrid>
    </DockPanel>
</Window>
